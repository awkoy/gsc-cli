{
  "name": "gsc-cli-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "LLM-friendly TypeScript CLI + SDK for Google Search Console",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:integration": "pnpm -r test:integration",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
