{
  "name": "@gsc-cli/sdk",
  "version": "0.0.2",
  "type": "module",
  "description": "TypeScript client for the Google Search Console API",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.ts --dir test/integration",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "clean": "rm -rf dist coverage .tsbuildinfo .tsbuildinfo.test tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "google-auth-library": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awkoy/gsc-cli.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
